# === LLM Config ===
[llm]
# api_type auto-detected by trying both providers. Set explicitly if auto-detect fails:
# api_type = "openai"       # openai | anthropic
api_key = "your-api-key"
model = "gpt-4.1-mini"
# base_url = "https://api.openai.com/v1"

# === MCP Server ===
[mcp]
# Pre-funded testnet wallet (10 G) — ready to use, no faucet needed
private_key = "0x859b68e0eddb79598540a35dcd0f7cf4df7c7b8cad35151177439268566cbfa9"

# Gravity Alpha Testnet (default — contracts already deployed)
rpc_url = "https://rpc-testnet.gravity.xyz"
agent_registry_address = "0x0000000000000000000000000000000000000000"   # Update after deploy
agent_ledger_address = "0x0000000000000000000000000000000000000000"     # Update after deploy
location_ledger_address = "0x0000000000000000000000000000000000000000"  # Update after deploy
inbox_ledger_address = "0x0000000000000000000000000000000000000000"     # Update after deploy

# For local dev (anvil), uncomment these and comment out the testnet lines above:
# rpc_url = "http://127.0.0.1:8545"
# private_key = "0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80"
# Addresses auto-loaded from ../deployed-addresses.json after `forge script Deploy.s.sol`

# MCP server bind settings
host = "127.0.0.1"
port = 3005
path = "/mcp"

# OR: Connect to an existing MCP server (skip auto-launch)
# server_url = "http://127.0.0.1:3000/mcp"

# === Agent Runner Defaults ===
[runner]
loop_delay_ms = 8000
max_tool_rounds_per_cycle = 6
max_history_length = 20

# === Single-agent fallback (used only when accounts.json does not exist) ===
[agent]
id = 1
goal = "Explore the town, socialize actively, record important memories, and advance the world clock when the time is right."
